# Copy this file to `.env` and fill in real values.

# MongoDB connection string (local or Atlas)
MONGODB_URL=mongodb://localhost:27017/tripper

# Secret used to sign session cookies — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# Port the server listens on (optional; defaults to 8080)
PORT=8080

GEMINI_KEY=change-me-to-a-long-random-string